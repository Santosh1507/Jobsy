{
  "$schema": "https://railway.app/schema.json",
  "name": "jobsy",
  "builder": "DOCKER",
  "build": {
    "command": "docker build -t jobsy ."
  },
  "run": {
    "command": "docker run -p $PORT:$PORT jobsy"
  },
  "environment": [
    "PYTHONUNBUFFERED=1"
  ],
  "domains": [
    {
      "name": "jobsy"
    }
  ],
  "options": {
    "metadata": {
      "name": "Jobsy - WhatsApp Job Platform"
    }
  }
}