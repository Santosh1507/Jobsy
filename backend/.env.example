# Environment Configuration for Jobsy
# Copy this to .env and fill in your values

# ==================== APP ====================
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this

# ==================== DATABASE ====================
# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ==================== WHATSAPP META API ====================
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ==================== OLLAMA ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:70b
OLLAMA_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==================== JOB SCRAPING ====================
LINKEDIN_COOKIE=your-linkedin-cookie
NAUKRI_USERNAME=your-naukri-username
NAUKRI_PASSWORD=your-naukri-password

# ==================== EMAIL SERVICES ====================
APOLLO_API_KEY=your-apollo-api-key
HUNTER_API_KEY=your-hunter-api-key

# ==================== PAYMENT ====================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ==================== STORAGE ====================
RESUME_STORAGE_PATH=./storage/resumes

# ==================== RATE LIMITS ====================
MAX_APPLICATIONS_PER_DAY=20
DAILY_JOB_DROP_TIME=08:00
MESSAGE_RATE_LIMIT_PER_MINUTE=20

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== LOGGING ====================
LOG_LEVEL=INFO
SENTRY_DSN=